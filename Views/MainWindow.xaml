<Window x:Class="OmronPlcTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OmronPlcTool.ViewModels"
        xmlns:models="clr-namespace:OmronPlcTool.Models"
        xmlns:services="clr-namespace:OmronPlcTool.Services"
        Title="Omron/Keyence PLC Tool"
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection Bar -->
        <Border Grid.Row="0" Padding="8" Background="#F0F0F0" CornerRadius="4" Margin="0,0,0,8">
            <WrapPanel>
                <ComboBox ItemsSource="{Binding PlcModelNames}"
                          SelectedIndex="{Binding SelectedPlcModelIndex}"
                          Width="130" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding ProtocolNames}"
                          SelectedIndex="{Binding SelectedProtocolIndex}"
                          Width="140" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="地址:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Bold"/>
                <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                         Width="130" VerticalAlignment="Center" Margin="0,0,8,0"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                <TextBlock Text="节点:" VerticalAlignment="Center" Margin="0,0,4,0"
                           Visibility="{Binding SelectedProtocolIndex, Converter={StaticResource ProtocolToVisibilityConverter}}"/>
                <TextBox Text="{Binding PlcNodeAddress, UpdateSourceTrigger=PropertyChanged}"
                         Width="40" VerticalAlignment="Center" Margin="0,0,8,0"
                         Visibility="{Binding SelectedProtocolIndex, Converter={StaticResource ProtocolToVisibilityConverter}}"/>
                <Button Content="{Binding IsConnected, Converter={StaticResource ConnectButtonTextConverter}}"
                        Command="{Binding ConnectCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                        Width="80" Height="26"
                        Background="{Binding IsConnected, Converter={StaticResource ConnectColorConverter}}"
                        Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center"
                           Foreground="{Binding IsConnected, Converter={StaticResource StatusColorConverter}}"
                           FontWeight="SemiBold"/>
            </WrapPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Node Tree + Import -->
            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="变量浏览器" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="导入" Command="{Binding ImportSelectedCommand}"
                                Width="50" Height="24" Margin="10,0,4,0" FontSize="12"/>
                        <Button Content="全部" Command="{Binding ImportAllCommand}"
                                Width="50" Height="24" FontSize="12"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1"
                            Padding="6" CornerRadius="3" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="文件导入 / 手动添加" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#555" Margin="0,0,0,4"/>
                            <Button Content="导入变量文件 (CSV/TXT)" Command="{Binding ShowImportDialogCommand}"
                                    Height="26" FontSize="11"/>
                            <TextBox Text="{Binding ManualVariableInput, UpdateSourceTrigger=PropertyChanged}"
                                     Height="35" TextWrapping="Wrap" AcceptsReturn="True"
                                     FontSize="11" Margin="0,4,0,0"/>
                            <Button Content="添加手动变量" Command="{Binding AddManualVariablesCommand}"
                                    Height="24" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <TreeView Grid.Row="2" ItemsSource="{Binding TreeRootNodes}"
                              SelectedItemChanged="TreeView_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}"
                                                      DataType="{x:Type services:TreeNodeModel}">
                                <TextBlock Text="{Binding Name}"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- Right: Variable Monitor -->
            <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <WrapPanel>
                            <TextBlock Text="变量监控" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MonitoredVariables.Count, StringFormat=' ({0})'}"
                                       VerticalAlignment="Center" Margin="5,0,10,0" Foreground="Gray"/>

                            <Button Content="开始监控" Command="{Binding StartMonitoringCommand}"
                                    Width="80" Height="24" FontSize="12" IsEnabled="{Binding IsConnected}"
                                    Margin="0,0,10,0"/>

                            <TextBlock Text="搜索:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>

                            <CheckBox Content="层级视图" IsChecked="{Binding IsHierarchicalView}"
                                      VerticalAlignment="Center" Margin="0,0,6,0"/>

                            <!-- Expand/Collapse buttons (only enabled in hierarchical mode) -->
                            <Button Content="全部展开" Command="{Binding ExpandAllCommand}"
                                    Width="70" Height="24" FontSize="11" Margin="0,0,4,0"
                                    Visibility="{Binding IsHierarchicalView, Converter={StaticResource BoolToVisConverter}}"/>
                            <Button Content="全部折叠" Command="{Binding CollapseAllCommand}"
                                    Width="70" Height="24" FontSize="11"
                                    Visibility="{Binding IsHierarchicalView, Converter={StaticResource BoolToVisConverter}}"/>

                            <Button Content="批量删除" Command="{Binding BatchDeleteCommand}"
                                    Width="80" Height="24" FontSize="12" Margin="10,0,0,0"
                                    CommandParameter="{Binding SelectedItems, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    Visibility="{Binding IsHierarchicalView, Converter={StaticResource InvertBoolToVisConverter}}"/>
                        </WrapPanel>
                    </Grid>

                    <!-- Hint -->
                    <TextBlock Grid.Row="1" Text="提示: 双击「新值」列输入值后点「写入」。层级视图下可展开结构体/数组。"
                               FontSize="10" Foreground="Gray" Margin="0,0,0,4"/>

                    <!-- Flat DataGrid (visible when hierarchy OFF) -->
                    <DataGrid Grid.Row="2" x:Name="VariablesGrid"
                              ItemsSource="{Binding MonitoredVariables}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              SelectionMode="Extended" RowHeight="28"
                              Loaded="VariablesGrid_Loaded" PreviewKeyDown="VariablesGrid_KeyDown"
                              Visibility="{Binding IsHierarchicalView, Converter={StaticResource InvertBoolToVisConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="变量名" Binding="{Binding DisplayName}" Width="200" IsReadOnly="True"/>
                            <DataGridTextColumn Header="节点ID" Binding="{Binding NodeId}" Width="*" MinWidth="130" IsReadOnly="True"/>
                            <DataGridTextColumn Header="当前值" Binding="{Binding ValueDisplay}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="时间戳" Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}" Width="105" IsReadOnly="True"/>
                            <DataGridTextColumn Header="新值" Binding="{Binding NewValueInput, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                            <DataGridTemplateColumn Header="操作" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="写入" Width="48" Height="22" FontSize="12"
                                                    Command="{Binding DataContext.WriteValueCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="删除" Width="48" Height="22" FontSize="12" Margin="3,0,0,0"
                                                    Command="{Binding DataContext.RemoveVariableCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Hierarchical TreeView (visible when hierarchy ON) -->
                    <TreeView Grid.Row="2" x:Name="HierarchyTree"
                              ItemsSource="{Binding HierarchicalRoots}"
                              Visibility="{Binding IsHierarchicalView, Converter={StaticResource BoolToVisConverter}}">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}"
                                                      DataType="{x:Type models:HierarchicalVar}">
                                <Grid Margin="2,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Name with indent -->
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               FontWeight="{Binding IsFolder, Converter={StaticResource FolderFontWeightConverter}}"/>

                                    <!-- NodeId -->
                                    <TextBlock Grid.Column="1" Text="{Binding NodeId}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               Opacity="{Binding IsFolder, Converter={StaticResource FolderOpacityConverter}}"/>

                                    <!-- Value -->
                                    <TextBlock Grid.Column="2" Text="{Binding ValueDisplay}"
                                               VerticalAlignment="Center" Opacity="{Binding IsFolder, Converter={StaticResource FolderOpacityConverter}}"/>

                                    <!-- DataType -->
                                    <TextBlock Grid.Column="3" Text="{Binding DataType}"
                                               VerticalAlignment="Center"/>

                                    <!-- Timestamp -->
                                    <TextBlock Grid.Column="4" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                               VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>

                                    <!-- NewValue + Write -->
                                    <TextBox Grid.Column="5" Text="{Binding NewValueInput, UpdateSourceTrigger=PropertyChanged}"
                                             Width="80" FontSize="11" VerticalAlignment="Center"
                                             IsEnabled="{Binding IsFolder, Converter={StaticResource InvertBoolConverter}}"/>

                                    <WrapPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="写入" Width="44" Height="22" FontSize="11"
                                                Command="{Binding DataContext.WriteValueCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding IsFolder, Converter={StaticResource InvertBoolConverter}}"/>
                                        <Button Content="删除" Width="44" Height="22" FontSize="11" Margin="2,0,0,0"
                                                Command="{Binding DataContext.RemoveVariableCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                CommandParameter="{Binding}"/>
                                    </WrapPanel>
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Margin="0,6,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="PLC: "/><Run Text="{Binding SelectedPlcModelIndex, Converter={StaticResource PlcModelNameConverter}}"/>
                        <Run Text=" | 协议: "/><Run Text="{Binding SelectedProtocolIndex, Converter={StaticResource ProtocolTipShortConverter}}"/>
                        <Run Text=" | 支持多实例"/>
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center" Margin="20,0,0,0">
                        <Hyperlink Click="OpenLogFile" ToolTip="打开 OPC UA 调试日志">
                            <Run Text="📋 OPC UA 调试日志"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
